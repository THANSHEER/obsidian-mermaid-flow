{
	"name": "mermaid-flow",
	"version": "1.0.0",
	"description": "Visual WYSIWYG editor for Mermaid flowcharts inside Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"mermaid",
		"diagram",
		"flowchart",
		"visual-editor"
	],
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "^6.5.0",
		"@codemirror/view": "^6.38.0",
		"@types/node": "^20.11.0",
		"esbuild": "^0.20.0",
		"obsidian": "^1.5.7",
		"tslib": "^2.6.2",
		"typescript": "^5.4.0"
	}
}
