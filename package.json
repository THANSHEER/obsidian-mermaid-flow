{
	"name": "mermaid-flow",
	"version": "1.3.0",
	"description": "Visual WYSIWYG editor for Mermaid flowcharts inside Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"lint": "eslint src/**/*.ts",
		"validate": "node scripts/validate-manifest.cjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"mermaid",
		"diagram",
		"flowchart",
		"visual-editor"
	],
	"license": "GPL-3.0-or-later",
	"devDependencies": {
		"@codemirror/state": "^6.5.0",
		"@codemirror/view": "^6.38.6",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.9.1",
		"@typescript-eslint/eslint-plugin": "^8.60.0",
		"@typescript-eslint/parser": "^8.60.0",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.0",
		"jsdom": "^29.1.1",
		"obsidian": "^1.12.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vitest": "^4.1.8"
	}
}
