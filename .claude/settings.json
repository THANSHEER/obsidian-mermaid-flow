{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/guard-edit.cjs\"",
            "timeout": 30,
            "statusMessage": "Checking Obsidian audit rules…"
          }
        ]
      }
    ]
  }
}
